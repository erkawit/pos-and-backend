rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Unit Validation
    function isValidUnit(data) {
      return data.keys().hasAll(['id', 'name']) 
        && data.keys().size() >= 2
        && data.id is string
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    // Product Validation
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'cost', 'stock', 'unit'])
        && data.id is string
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number && data.price >= 0
        && data.cost is number && data.cost >= 0
        && data.stock is number
        && data.unit is string && data.unit.size() > 0;
    }

    // Member Validation
    function isValidMember(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'points'])
        && data.id is string
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.phone is string
        && data.points is number
        && (!data.keys().hasAny(['createdAt']) || data.createdAt is string)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt is string)
        && (!data.keys().hasAny(['memberCode']) || data.memberCode is string)
        && (!data.keys().hasAny(['birthday']) || data.birthday is string);
    }

    // MemberCard Validation
    function isValidMemberCard(data) {
      return data.keys().hasAll(['id', 'code', 'status', 'createdAt'])
        && data.id is string
        && data.code is string && data.code.size() > 0
        && data.status is string && (data.status == 'available' || data.status == 'assigned')
        && data.createdAt is string
        && (!data.keys().hasAny(['assignedToMemberId']) || data.assignedToMemberId is string)
        && (!data.keys().hasAny(['assignedToMemberName']) || data.assignedToMemberName is string);
    }

    // Sale Validation
    function isValidSale(data) {
      return data.keys().hasAll(['id', 'invoiceId', 'date', 'items', 'totalAmount'])
        && data.id is string
        && data.invoiceId is string && data.invoiceId.size() > 0
        && data.date is string && data.date.size() == 10
        && data.items is list && data.items.size() >= 0
        && data.totalAmount is number && data.totalAmount >= 0;
    }

    // Settings Validation
    function isValidSettings(data) {
      return data.keys().hasAll(['logo', 'nameEng', 'nameThai', 'themeColor'])
        && data.logo is string
        && data.nameEng is string && data.nameEng.size() > 0 && data.nameEng.size() <= 100000
        && data.nameThai is string && data.nameThai.size() > 0 && data.nameThai.size() <= 100000
        && data.themeColor is string;
    }

    match /units/{unitId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(unitId) && isValidUnit(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(productId) && isValidProduct(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(memberId) && isValidMember(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /memberCards/{cardId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(cardId) && isValidMemberCard(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(saleId) && isValidSale(request.resource.data);
      allow update: if isSignedIn() && isValidId(saleId) && isValidSale(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /settings/{settingsId} {
      allow read: if true; // Let settings load before auth
      allow create, update: if isSignedIn() && isValidId(settingsId);
      allow delete: if isSignedIn();
    }

    match /_test_connection_path/{docId} {
      allow read: if true;
    }
  }
}
